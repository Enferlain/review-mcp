# API key for GLM-4.7 (required)
AI_API_KEY=your_api_key_here

# Backward-compatible fallback key name
# ZHIPU_API_KEY=your_api_key_here

# Optional: Override the API base URL
# ZHIPU_BASE_URL=https://api.z.ai/api/coding/paas/v4

# Optional: Max iterations for agentic review (default: 20, capped at 50)
# MAX_REVIEW_ITERATIONS=20

# Optional: Include diagnostic trace details in review responses
# REVIEW_MCP_INCLUDE_TRACE=false
